\item{sbhm_amplitude}{Named list controlling amplitude estimation inside SBHM (method, ridge, SE return, etc.).}
\item{sbhm_prewhiten}{Prewhitening specification for SBHM; defaults to \code{lss_prewhiten}.}
\item{resample_events}{If \code{TRUE}, trial onsets are resampled independently for each repetition rather than held fixed across reps.}
\item{fast_mode}{If \code{TRUE}, silently reduces \code{n_reps}, \code{n_vox}, \code{n_trials}, and \code{n_tp} to minimal values for rapid testing.}
\item{trace}{If \code{TRUE}, print progress messages to the console.}
\item{scenarios}{Named list of scenario argument lists, or the output of \code{default_benchmark_scenarios()}.}
