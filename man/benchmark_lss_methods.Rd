}
\value{
\code{benchmark_lss_methods()} returns an object of class
\code{lss_benchmark}, a list with the following components:

\describe{
  \item{params}{Named list recording all input parameters, including \code{fast_mode} and \code{resample_events}.}
  \item{primary_st}{Character name of the stglmnet configuration used for head-to-head comparisons.}
  \item{metrics}{Data frame with one row per repetition and columns \code{cor_st}, \code{cor_lss}, \code{rmse_st}, \code{rmse_lss}, \code{slope_bias_st}, \code{slope_bias_lss}, \code{intercept_bias_st}, \code{intercept_bias_lss}, \code{sign_acc_st}, \code{sign_acc_lss}.}
  \item{summary}{Named list of aggregated statistics: column means, medians, SDs, win-rate comparisons, and delta summaries for correlation, RMSE, sign accuracy, and regression bias.}
  \item{metrics_long}{Long-format data frame with one row per (repetition, method) combination. Columns include \code{rep}, \code{method}, \code{cor}, \code{rmse}, \code{slope_bias}, \code{intercept_bias}, \code{sign_acc}, \code{elapsed_sec} (wall time in seconds), and \code{classif_acc} (condition classification accuracy when \code{n_conditions > 0}, otherwise \code{NA}).}
  \item{method_summary}{Data frame of per-method aggregates: mean correlation, RMSE, success rate, mean elapsed time, and mean classification accuracy.}
  \item{sbhm_diag_long}{Long-format data frame of SBHM-specific diagnostics (empty when \code{include_sbhm = FALSE}).}
  \item{true_hrf_diag_long}{Long-format data frame of true-HRF recovery diagnostics across repetitions.}
  \item{oasis_grid}{Data frame of the OASIS hyperparameter grid actually evaluated.}
}

\code{benchmark_lss_methods_suite()} returns an object of class
\code{lss_benchmark_suite}, a list with:

\describe{
  \item{scenarios}{Character vector of scenario names.}
  \item{scenario_args}{List of per-scenario argument lists.}
  \item{results}{List of \code{lss_benchmark} objects, one per scenario.}
  \item{metrics_long}{Combined long-format metrics data frame with an additional \code{scenario} column.}
  \item{sbhm_diag_long}{Combined SBHM diagnostics with a \code{scenario} column.}
  \item{true_hrf_diag_long}{Combined true-HRF diagnostics with a \code{scenario} column.}
  \item{scenario_method_summary}{Data frame of per-(scenario, method) aggregates.}
  \item{pairwise_summary}{Data frame of per-scenario head-to-head statistics (primary stglmnet vs. fmrilss LSS) including Wilcoxon p-values and empirical CIs for correlation and RMSE differences.}
  \item{top_by_cor}{Data frame identifying the best method by mean correlation for each scenario.}
}

\code{default_benchmark_scenarios()} returns a named list of scenario
argument lists suitable for passing to \code{benchmark_lss_methods_suite()}.
}
\examples{
\dontrun{
# Quick single-scenario benchmark
res <- benchmark_lss_methods(n_reps = 5, n_vox = 4, fast_mode = TRUE)
res$summary$delta_corr_mean

# Multi-scenario suite
suite <- benchmark_lss_methods_suite(
  scenarios = default_benchmark_scenarios("quick"),
  base_args = list(fast_mode = TRUE)
)
suite$pairwise_summary
}
}
