\item{hrfals_basis}{HRF basis used for ALS estimation; must have \code{nbasis > 1}.}
\item{hrfals_control}{Named list of control parameters forwarded to the HRF-ALS fitter.}
\item{include_sbhm}{If \code{TRUE}, include the Shared-Basis HRF Model in the comparison.}
\item{sbhm_rank}{Rank of the shared HRF basis decomposition.}
\item{sbhm_library_H}{Pre-built HRF library matrix; \code{NULL} constructs a default library.}
