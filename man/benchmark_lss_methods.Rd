\item{true_hrf_widen_sec}{Seconds of global HRF widening applied to the true signal.}
\item{true_hrf_lag_vox_sd}{Standard deviation of voxel-specific HRF lag (seconds).}
\item{true_hrf_widen_vox_sd}{Standard deviation of voxel-specific HRF widening (seconds).}
\item{true_hrf_lag_trial_sd}{Standard deviation of trial-specific HRF lag (seconds).}
\item{true_hrf_widen_trial_sd}{Standard deviation of trial-specific HRF widening (seconds).}
\item{avoid_duplicate_regressors}{If \code{TRUE}, trials with nearly collinear regressors are jittered until they are distinct.}
\item{duplicate_tol}{Correlation threshold above which two regressors are considered duplicates.}
\item{duplicate_max_iter}{Maximum jitter rounds when resolving duplicate regressors.}
\item{duplicate_jitter_step}{Jitter step size (seconds); \code{NULL} uses an automatic default.}
