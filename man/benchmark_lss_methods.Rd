\section{Parameter groupings}{
Parameters are logically grouped as follows:

\strong{Simulation dimensions:} \code{n_reps}, \code{seed}, \code{n_tp}, \code{n_trials}, \code{n_vox}, \code{n_runs}.

\strong{Inter-stimulus interval:} \code{isi}, \code{isi_model}, \code{isi_params}, \code{tr}.

\strong{Noise model:} \code{noise_sd}, \code{noise_model}, \code{ar_rho}, \code{ar_rho_sd}, \code{ar_rho_vox_sd}, \code{ar_phi2}, \code{arma_theta}, \code{noise_spike_prob}, \code{noise_spike_scale}, \code{noise_spike_shared}, \code{noise_innov_dist}, \code{noise_df}, \code{spatial_rho}.

\strong{Beta / signal model:} \code{beta_sparsity}, \code{beta_dist}, \code{beta_scale}, \code{beta_df}, \code{beta_lognorm_sdlog}, \code{n_conditions}, \code{condition_effect}, \code{trial_amplitude_model}, \code{trial_amplitude_cv}, \code{trial_amplitude_outlier_prob}, \code{trial_amplitude_outlier_scale}.

\strong{HRF model and mismatch:} \code{basis}, \code{true_basis}, \code{onset_jitter_sd}, \code{true_onset_shift_sd}, \code{true_hrf_lag_sec}, \code{true_hrf_widen_sec}, \code{true_hrf_lag_vox_sd}, \code{true_hrf_widen_vox_sd}, \code{true_hrf_lag_trial_sd}, \code{true_hrf_widen_trial_sd}.

\strong{Duplicate-regressor handling:} \code{avoid_duplicate_regressors}, \code{duplicate_tol}, \code{duplicate_max_iter}, \code{duplicate_jitter_step}.

\strong{stglmnet configuration:} \code{alpha}, \code{lambda}, \code{overlap_adaptive}, \code{st_configs}, \code{primary_st}, \code{cv_folds}, \code{cv_type.measure}.

\strong{fmrilss LSS configuration:} \code{lss_method}, \code{lss_intercept}, \code{st_match_lss_nuisance}, \code{lss_prewhiten}.

\strong{Optional OASIS method:} \code{include_oasis}, \code{oasis_grid}, \code{oasis_prewhiten}.

\strong{Optional HRF-ALS method:} \code{include_hrfals}, \code{hrfals_modes}, \code{hrfals_lambda_ridge}, \code{hrfals_fit_methods}, \code{hrfals_basis}, \code{hrfals_control}.

