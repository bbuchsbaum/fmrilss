\item{trial_amplitude_outlier_prob}{Probability of an outlier trial amplitude.}
\item{trial_amplitude_outlier_scale}{Multiplier applied to outlier trial amplitudes.}
\item{basis}{HRF basis used when constructing the estimation design matrix (passed to \pkg{fmrihrf}).}
\item{true_basis}{HRF basis used to generate the true signal; defaults to \code{basis}.}
\item{onset_jitter_sd}{Standard deviation (seconds) of additive jitter applied to nominal trial onsets.}
\item{true_onset_shift_sd}{Standard deviation (seconds) of a systematic onset shift in the true design.}
