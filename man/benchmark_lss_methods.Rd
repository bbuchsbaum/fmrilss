\item{cv_folds}{Number of cross-validation folds for lambda selection.}
\item{cv_type.measure}{CV loss metric: \code{"auto"}, \code{"mse"}, \code{"correlation"}, \code{"reliability"}, or \code{"composite"}.}
\item{lss_method}{LSS backend passed to \code{lss()}; default is \code{"r_optimized"}.}
